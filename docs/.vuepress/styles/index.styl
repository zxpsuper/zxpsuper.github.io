@import('https://gw.alipayobjects.com/os/k/font/lxgwwenkaiscreenr.css')
@import('https://gw.alipayobjects.com/os/k/t/comment.css')

body
  font-family 'LXGW WenKai Screen R'

.flex
  display flex

.y-center
  align-items center

.flex1
  flex 1

.mb-16
  margin-bottom 16px
  
#header
  box-shadow none

.header-wrapper .title a
  font-family 'LXGW WenKai Screen R'!important

.header-wrapper .header-right-wrap .nav .nav-item a
  font-family 'LXGW WenKai Screen R'!important

.ui-post
  background-color #fff
  margin-bottom 30px;
  padding 30px 50px 16px;
  box-shadow 0 0 0 0,0 6px 12px rgba(36,41,47,.1)
  border-radius 8px
  border 1px solid #e3e8f7

.ui-post-title,.vuepress-blog-theme-content,h1, h2, h3, h4, h5, h6
  font-family 'LXGW WenKai Screen R'!important

.pagination
  display: flex!important;
  justify-content: center;

.blog-tags
  width 100%!important


@media (max-width: 959px) {
  .vuepress-blog-theme-content {
      padding: 16px!important;
  }
}
.vuepress-blog-theme-content, .content-wrapper
  max-width 860px!important

.vuepress-blog-theme-content
  border-radius 8px
  border 1px solid #e3e8f7

.content-wrapper 
  padding 120px 15px 80px 15px
  min-height: calc(100vh - 262px);

#app {
  background-color:#f7f9fe;
}

/* Tags Page Styles */
.blog-tags
  width 100%!important
  background transparent
  padding 0

.blog-tags h2
  font-size 28px
  font-weight 700
  color #1a1a1a
  margin-bottom 32px
  display flex
  align-items center
  gap 12px
  padding-left 4px

.blog-tags h2::before
  content '🏷️'
  font-size 32px

.tag-wrapper
  display flex
  flex-wrap wrap
  gap 16px
  margin-bottom 32px


.blog-tag
  width: fit-content!important;
  color: #363636!important;
  background: #fff!important;
  border: 1px solid #e3e8f7!important;
  box-shadow: 0 8px 16px -4px #2c2d300c!important;
  backface-visibility: hidden!important;
  transform-style: preserve-3d!important;
  border-radius: 12px!important;
  align-items: center!important;
  gap: 6px!important;
  margin: .7rem!important;
  padding: .6rem .7rem!important;
  font-size: 1.4rem!important;
  transition: all .2s!important;
.tag .tag-name
  font-weight 600
  letter-spacing 0.5px

.tag .tag-count
  display inline-flex
  align-items center
  justify-content center
  min-width 24px
  height 24px
  background rgba(255, 255, 255, 0.25)
  color #fff
  font-size 13px
  font-weight 700
  border-radius 12px
  padding 0 8px
  backdrop-filter blur(4px)

/* Tag details page styles */
.theme-blog-tag
  background transparent
  padding 0

.theme-blog-tag h2
  font-size 28px
  font-weight 700
  color #1a1a1a
  margin-bottom 32px
  display flex
  align-items center
  gap 12px

.theme-blog-tag h2::before
  content '📁'
  font-size 32px

.theme-blog-tag .tag-item-list
  list-style none
  padding 0
  margin 0

.theme-blog-tag .tag-item
  padding 0
  margin-bottom 12px
  border none

.theme-blog-tag .tag-item a
  display flex
  justify-content space-between
  align-items center
  text-decoration none
  color #333
  font-size 16px
  font-weight 500
  transition all 0.3s ease
  padding 16px 20px
  border-radius 12px
  background #fff
  border 1px solid #e8e8e8
  box-shadow 0 2px 8px rgba(0, 0, 0, 0.04)

.theme-blog-tag .tag-item a:hover
  background linear-gradient(135deg, #667eea 0%, #764ba2 100%)
  color #fff
  transform translateX(8px)
  border-color transparent
  box-shadow 0 8px 25px rgba(102, 126, 234, 0.35)

.theme-blog-tag .tag-item a .tag-item-title
  flex 1
  transition all 0.3s ease

.theme-blog-tag .tag-item a:hover .tag-item-title
  padding-left 8px

.theme-blog-tag .tag-item a .tag-item-date
  font-size 14px
  color #999
  font-weight 400
  transition all 0.3s ease

.theme-blog-tag .tag-item a:hover .tag-item-date
  color rgba(255, 255, 255, 0.9)


.content__default:not(.custom) a:hover {
    text-decoration: none;
}

@media (max-width: 640px)
  .blog-tags h2
    font-size 24px

  .tag-wrapper
    gap 12px

  .tag
    padding 10px 18px
    font-size 14px

  .tag .tag-count
    min-width 20px
    height 20px
    font-size 12px

  .theme-blog-tag h2
    font-size 24px

  .theme-blog-tag .tag-item a
    padding 14px 16px
    font-size 15px
