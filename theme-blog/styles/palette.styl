// CSS custom properties for kai.bi style
:root
  --bg: #ffffff
  --bg-subtle: #fafafa
  --bg-card: #ffffff
  --text: #171717
  --text-secondary: #525252
  --text-tertiary: #a3a3a3
  --border: #e5e7eb
  --border-dashed: #d4d4d4
  --hover-border: #a3a3a3
  --accent: #171717
  --accent-text: #ffffff
  --separator-bg: #ffffff
  --header-bg: rgba(255,255,255,0.9)

html.dark
  --bg: #0a0a0a
  --bg-subtle: #171717
  --bg-card: #0a0a0a
  --text: #f5f5f5
  --text-secondary: #a3a3a3
  --text-tertiary: #737373
  --border: #262626
  --border-dashed: #404040
  --hover-border: #525252
  --accent: #ffffff
  --accent-text: #171717
  --separator-bg: #171717
  --header-bg: rgba(10,10,10,0.9)
