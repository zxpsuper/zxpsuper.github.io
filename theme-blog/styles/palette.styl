// colors
$accentColor = #3eaf7c
$textColor = #171717
$darkTextColor = #171717
$borderColor = rgba(0,0,0,.05)
$darkBorderColor = #000
$codeBgColor = #000
$bgColor = #ffffff
$headerBgColor = #ffffff
$footerBgColor = #000
$footerColor = #828282
$newsletterBgColor = #f8f8f8
$postTagBgColor = #ededed
$postTagColor = darken($postTagBgColor,50%)

// layout
$headerHeight = 80px
$contentWidth = 900px

// responsive breakpoints
$MQNarrow = 959px
$MQMobile = 719px
$MQMobileNarrow = 419px

// code
